<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Elyse's Cosmic 17th Birthday</title>

<style>

body{
margin:0;
font-family:Arial;
color:white;
text-align:center;
background:black;
overflow-x:hidden;
}

/* starfield */

.star{
position:fixed;
width:2px;
height:2px;
background:white;
opacity:.8;
}

/* shooting stars */

.shooting{
position:fixed;
width:3px;
height:3px;
background:white;
box-shadow:0 0 6px white;
}

/* title */

h1{
font-size:55px;
margin-top:40px;
animation:glow 2s infinite alternate;
}

@keyframes glow{
from{ text-shadow:0 0 10px white;}
to{ text-shadow:0 0 35px #7aa8ff;}
}

section{
padding:40px;
}

.card{
background:rgba(255,255,255,0.08);
padding:25px;
border-radius:15px;
max-width:900px;
margin:auto;
}

/* solar system */

.orbit{
border:1px dashed rgba(255,255,255,.3);
border-radius:50%;
position:absolute;
top:50%;
left:50%;
}

.planet{
width:18px;
height:18px;
background:#ff7be5;
border-radius:50%;
position:absolute;
top:-9px;
left:50%;
}

.rotate{
animation:spin 25s linear infinite;
}

@keyframes spin{
from{transform:rotate(0deg)}
to{transform:rotate(360deg)}
}

/* dna */

#dna{
font-size:30px;
animation:spin 6s linear infinite;
}

/* books */

.book{
font-size:40px;
cursor:pointer;
margin:10px;
}

/* cat game */

.cat{
font-size:50px;
cursor:pointer;
position:absolute;
}

/* microscope */

#slides img{
width:200px;
border-radius:10px;
margin:10px;
cursor:pointer;
}

#viewer img{
width:350px;
border-radius:12px;
}

/* cake */

.candle{
font-size:35px;
cursor:pointer;
}

/* balloons */

.balloon{
font-size:40px;
cursor:pointer;
}

button{
padding:10px 18px;
border:none;
border-radius:8px;
background:#ff7be5;
color:white;
cursor:pointer;
}

</style>
</head>

<body>

<audio autoplay loop>
<source src="https://cdn.pixabay.com/audio/2022/03/15/audio_c8c8a73467.mp3">
</audio>

<h1>🎉 Happy 17th Birthday Elyse 🎉</h1>
<p>A universe celebrating astronomy, books, cats, anatomy & histology</p>

<!-- SOLAR SYSTEM -->

<div class="orbit rotate" style="width:350px;height:350px;margin-left:-175px;margin-top:-175px;">
<div class="planet"></div>
</div>

<!-- ASTRONOMY -->

<section>
<div class="card">

<h2>🌌 Elyse's Cosmic Observatory</h2>

<p>
The universe contains billions of galaxies and endless mysteries.
Just like the cosmos, Elyse's future is full of incredible discoveries.
</p>

</div>
</section>

<!-- DNA -->

<section>
<div class="card">

<h2>🧬 DNA Discovery Lab</h2>

<div id="dna">🧬</div>

<p>
Science, anatomy, and histology reveal the incredible complexity
of life at the microscopic level.
</p>

</div>
</section>

<!-- BOOKS -->

<section>
<div class="card">

<h2>📚 Elyse's Library</h2>

<p>Click a book to get a recommendation.</p>

<span class="book" onclick="book('science')">📘</span>
<span class="book" onclick="book('fantasy')">📙</span>
<span class="book" onclick="book('mystery')">📕</span>

<p id="bookResult"></p>

</div>
</section>

<!-- CAT GAME -->

<section>
<div class="card">

<h2>🐱 Cat Chase Game</h2>
<p>Catch the cat!</p>

<div id="catGame" style="height:250px;position:relative;"></div>

<p>Score: <span id="catScore">0</span></p>

</div>
</section>

<!-- HISTOLOGY -->

<section>
<div class="card">

<h2>🔬 Histology Microscope</h2>

<div id="slides">

<img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b"
onclick="zoom(this)">

<img src="https://images.unsplash.com/photo-1579154204601-01588f351e67"
onclick="zoom(this)">

<img src="https://images.unsplash.com/photo-1581092334651-ddf26d9a09d0"
onclick="zoom(this)">

</div>

<div id="viewer"></div>

</div>
</section>

<!-- CAKE -->

<section>
<div class="card">

<h2>🎂 Elyse's Birthday Cake</h2>

<span class="candle" onclick="blow(this)">🕯️</span>
<span class="candle" onclick="blow(this)">🕯️</span>
<span class="candle" onclick="blow(this)">🕯️</span>
<span class="candle" onclick="blow(this)">🕯️</span>

<p id="wish"></p>

</div>
</section>

<!-- BALLOONS -->

<section>
<div class="card">

<h2>🎈 Balloon Pop Game</h2>

<div id="balloons"></div>

<p>Score: <span id="score">0</span></p>

<h2 id="win" style="display:none;">🎉 Happy Birthday Elyse! 🎉</h2>

</div>
</section>

<script>

/* starfield */

for(let i=0;i<250;i++){
let s=document.createElement("div");
s.className="star";
s.style.left=Math.random()*100+"vw";
s.style.top=Math.random()*100+"vh";
document.body.appendChild(s);
}

/* shooting stars */

setInterval(()=>{
let s=document.createElement("div");
s.className="shooting";
s.style.left=Math.random()*100+"vw";
s.style.top="0px";
document.body.appendChild(s);

let fall=setInterval(()=>{

s.style.top=(s.offsetTop+8)+"px";
s.style.left=(s.offsetLeft+4)+"px";

if(s.offsetTop>window.innerHeight){
s.remove();
clearInterval(fall);
}

},20);

},4000);

/* books */

function book(type){

let text="";

if(type=="science")
text="Elyse should explore a science book about the universe or anatomy!";

if(type=="fantasy")
text="A magical fantasy adventure awaits Elyse.";

if(type=="mystery")
text="A mystery novel would keep Elyse guessing!";

document.getElementById("bookResult").innerText=text;

}

/* cat game */

let catScore=0;
let cat=document.createElement("div");
cat.className="cat";
cat.innerHTML="🐱";

function moveCat(){

cat.style.left=Math.random()*80+"%";
cat.style.top=Math.random()*180+"px";

}

cat.onclick=function(){

catScore++;
document.getElementById("catScore").innerText=catScore;
moveCat();

}

document.getElementById("catGame").appendChild(cat);
moveCat();

/* microscope zoom */

function zoom(img){

document.getElementById("viewer").innerHTML=
"<img src='"+img.src+"'>";

}

/* cake */

let candles=0;

function blow(c){

c.innerHTML="💨";
candles++;

if(candles==4)
document.getElementById("wish").innerText=
"✨ Elyse made a birthday wish!";

}

/* balloons */

let score=0;

function spawn(){

let b=document.createElement("span");
b.className="balloon";
b.innerHTML="🎈";

b.onclick=function(){

score++;
document.getElementById("score").innerText=score;
b.remove();

if(score>=10){

document.getElementById("win").style.display="block";
confetti();

}else{
spawn();
}

}

document.getElementById("balloons").appendChild(b);

}

spawn();

/* confetti */

function confetti(){

for(let i=0;i<120;i++){

let c=document.createElement("div");

c.style.position="fixed";
c.style.width="6px";
c.style.height="6px";
c.style.background="hsl("+Math.random()*360+"deg,100%,50%)";
c.style.left=Math.random()*100+"vw";
c.style.top="-10px";

document.body.appendChild(c);

let fall=setInterval(()=>{

c.style.top=(c.offsetTop+5)+"px";

if(c.offsetTop>window.innerHeight){
c.remove();
clearInterval(fall);
}

},20);

}

}

</script>

</body>
</http
